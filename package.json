{
  "name": "eso-notas-local",
  "version": "0.1.28",
  "description": "Aplicacion local para gestionar notas ESO en una plantilla Excel.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "node scripts/bump-version.js && tauri build",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "es.seba.esonotas",
    "productName": "ESO Gestor de Notas ",
    "files": [
      "index.html",
      "gestor-alumnos.html",
      "gestor-rraa-criterios.html",
      "gestor-unidades.html",
      "gestor-notas.html",
      "incluir-actividad.html",
      "visor-notas.html",
      "visor-actividades.html",
      "informes.html",
      "app-bridge.js",
      "tauri-node-backend.js",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "jszip": "^3.10.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.1",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  }
}
