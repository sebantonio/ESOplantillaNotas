{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ESO Notas Local",
  "version": "0.1.123",
  "identifier": "es.seba.esonotas",
  "build": {
    "beforeDevCommand": "node scripts/prepare-tauri-web.js",
    "beforeBuildCommand": "node scripts/prepare-tauri-web.js",
    "frontendDist": "../tauri-web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ESO Notas Local",
        "url": "index.html",
        "width": 1200,
        "height": 850,
        "minWidth": 900,
        "minHeight": 650,
        "maximized": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": []
  }
}
